# ──────────────────────────────────────────────
# PullMatch — root environment reference
# Copy to apps/api/.env and fill in values.
# ──────────────────────────────────────────────

PORT=3000

# ── GitHub App credentials (recommended) ──────
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# ── Fallback: personal access token ──────────
# Used when App credentials are not set (single-org / local testing).
# Needs repo read + write:discussion permissions.
# GITHUB_TOKEN_WRITE=ghp_your-token-here

# ── Optional ─────────────────────────────────
# NODE_ENV=development
# LOG_FORMAT=json
