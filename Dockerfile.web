# ─── Stage 1: Install dependencies ───────────────────────────
FROM node:22-alpine AS deps

WORKDIR /app

# Install pnpm
ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH
RUN corepack enable && corepack prepare pnpm@10.11.0 --activate

# Copy workspace config and package manifests
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY apps/web/package.json apps/web/package.json
COPY packages/shared/package.json packages/shared/package.json

RUN pnpm install --frozen-lockfile

# ─── Stage 2: Build the Next.js app ─────────────────────────
FROM node:22-alpine AS builder

WORKDIR /app

ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH
RUN corepack enable && corepack prepare pnpm@10.11.0 --activate

# Copy installed dependencies
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/apps/web/node_modules ./apps/web/node_modules
COPY --from=deps /app/packages/shared/node_modules ./packages/shared/node_modules

# Copy workspace config
COPY package.json pnpm-workspace.yaml ./

# Copy source
COPY apps/web ./apps/web
COPY packages/shared ./packages/shared

# Build-time env vars (defaults, overridden by Railway env vars)
ARG NEXT_PUBLIC_API_URL=https://pullmatch-production.up.railway.app
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

WORKDIR /app/apps/web
RUN pnpm build

# ─── Stage 3: Production image ──────────────────────────────
FROM node:22-alpine AS runner

RUN addgroup -S pullmatch && adduser -S pullmatch -G pullmatch

WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

# Copy standalone output from Next.js build
COPY --from=builder /app/apps/web/.next/standalone ./
COPY --from=builder /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder /app/apps/web/public ./apps/web/public

RUN chown -R pullmatch:pullmatch /app

USER pullmatch

EXPOSE 3000

CMD ["node", "apps/web/server.js"]
