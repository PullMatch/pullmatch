# ──────────────────────────────────────────────
# PullMatch API — local environment
# Copy this file to .env and fill in values.
# ──────────────────────────────────────────────

# Required — server will refuse to start without these
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# GitHub App authentication (recommended for multi-org)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=

# Fallback token — used when App credentials are not set (local testing)
# Needs: repo read + write:discussion permissions
# GITHUB_TOKEN_WRITE=ghp_your-github-token-here

# Optional — defaults shown
PORT=3000
NODE_ENV=development
# LOG_FORMAT=json
